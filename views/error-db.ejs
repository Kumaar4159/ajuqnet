<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connection Issue — AJUQNET</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body {
      background: #0f172a;
      color: #e2e8f0;
      font-family: 'Segoe UI', system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .error-card {
      background: #1e293b;
      border-radius: 1rem;
      padding: 3rem 2.5rem;
      max-width: 480px;
      width: 100%;
      text-align: center;
      box-shadow: 0 25px 50px rgba(0,0,0,.4);
    }
    .pulse {
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: .4; }
    }
    .retry-btn {
      background: #3b82f6;
      border: none;
      color: #fff;
      padding: .6rem 2rem;
      border-radius: .5rem;
      font-size: 1rem;
      cursor: pointer;
      margin-top: 1.5rem;
      transition: background .2s;
    }
    .retry-btn:hover { background: #2563eb; }
    .status-dot {
      width: 12px;
      height: 12px;
      background: #ef4444;
      border-radius: 50%;
      display: inline-block;
      margin-right: .4rem;
    }
  </style>
</head>
<body>
  <div class="error-card">

    <div class="fs-1 mb-3 pulse">🌐</div>

    <h4 class="fw-bold mb-2">Internet Connection Issue</h4>

    <p class="text-muted mb-4">
      AJUQNET could not reach the database server.<br>
      This is usually caused by a slow or dropped internet connection.
    </p>

    <div class="d-flex align-items-center justify-content-center gap-2 mb-2"
         style="font-size:.85rem">
      <span class="status-dot" id="statusDot"></span>
      <span id="statusText">Checking connection…</span>
    </div>

    <div style="font-size:.75rem;color:#475569" id="retryCountdown"></div>

    <button class="retry-btn" onclick="location.reload()">
      <i class="bi bi-arrow-clockwise me-1"></i> Try Again
    </button>

    <div class="mt-4" style="font-size:.75rem;color:#334155">
      If this keeps happening, ask your system administrator<br>
      to check the internet connection on the server PC.
    </div>

  </div>

  <script>
    // Auto retry countdown
    let seconds = 15;
    const countdownEl = document.getElementById('retryCountdown');
    const dotEl       = document.getElementById('statusDot');
    const statusEl    = document.getElementById('statusText');

    const timer = setInterval(function () {
      seconds--;
      countdownEl.textContent = 'Auto-retrying in ' + seconds + ' seconds…';
      if (seconds <= 0) {
        clearInterval(timer);
        countdownEl.textContent = 'Retrying now…';
        location.reload();
      }
    }, 1000);

    // Check if connection is back every 5 seconds
    setInterval(async function () {
      try {
        const r = await fetch('/auth/login', { method: 'HEAD' });
        if (r.ok) {
          dotEl.style.background  = '#22c55e';
          statusEl.textContent    = 'Connection restored — reloading…';
          countdownEl.textContent = '';
          setTimeout(() => location.reload(), 1000);
        }
      } catch (e) {
        dotEl.style.background = '#ef4444';
        statusEl.textContent   = 'Still disconnected';
      }
    }, 5000);
  </script>
</body>
</html>