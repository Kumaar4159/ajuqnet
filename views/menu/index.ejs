<%- include('../partials/layout_start') %>

<!-- Filter bar -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-2">
    <form class="d-flex flex-wrap gap-2 align-items-center" method="GET">
      <select name="category" class="form-select form-select-sm" style="width:160px">
        <option value="">All categories</option>
        <% categories.forEach(c => { %><option value="<%= c %>" <%=filter.category===c?'selected':''%>><%= c.charAt(0).toUpperCase()+c.slice(1) %></option><% }) %>
      </select>
      <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox" name="vegetarian" value="1" id="veg" <%=filter.vegetarian==='1'?'checked':''%>>
        <label class="form-check-label small" for="veg">🥦 Veg only</label>
      </div>
      <button type="submit" class="btn btn-primary btn-sm">Filter</button>
      <a href="/menu" class="btn btn-outline-secondary btn-sm">Reset</a>
      <% if (user && (user.role==='admin')) { %>
        <a href="/menu/new" class="btn btn-success btn-sm ms-auto"><i class="bi bi-plus-lg me-1"></i>Add Item</a>
      <% } %>
    </form>
  </div>
</div>

<% if (Object.keys(grouped).length === 0) { %>
  <div class="text-center py-5 text-muted"><i class="bi bi-search fs-1"></i><div class="mt-2">No menu items found.</div></div>
<% } %>

<% categories.forEach(cat => { if (!grouped[cat]) return; %>
<div class="mb-4">
  <h5 class="fw-bold text-uppercase text-muted small mb-3 d-flex align-items-center gap-2">
    <span class="category-dot"></span><%= cat.charAt(0).toUpperCase()+cat.slice(1) %>
  </h5>
  <div class="row g-3">
    <% grouped[cat].forEach(item => { %>
    <div class="col-sm-6 col-lg-4 col-xl-3">
      <div class="card menu-card border-0 shadow-sm h-100 <%= !item.isAvailable ? 'opacity-50' : '' %>">
        <div class="card-body d-flex flex-column">
          <div class="d-flex justify-content-between align-items-start mb-1">
            <h6 class="fw-semibold mb-0 me-2"><%= item.name %></h6>
            <% if (item.isVegetarian) { %><span class="veg-dot" title="Vegetarian">🟢</span><% } %>
          </div>
          <p class="text-muted small flex-grow-1 mb-2"><%= item.description || '' %></p>
          <div class="d-flex justify-content-between align-items-center mt-auto">
            <span class="fw-bold text-primary">₹<%= item.price %></span>
            <div class="d-flex gap-1">
              <% if (!item.isAvailable) { %><span class="badge bg-secondary">Unavailable</span><% } %>
              <% if (item.stock !== null) { %><span class="badge bg-light text-dark border">Stock: <%= item.stock %></span><% } %>
            </div>
          </div>
          <div class="mt-2 d-flex gap-1">
            <a href="/orders/new" class="btn btn-success btn-sm flex-grow-1"><i class="bi bi-bag-plus"></i> Order</a>
            <% if (user && (user.role==='admin')) { %>
              <a href="/menu/<%= item._id %>/edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
              <% if (user.role==='admin') { %>
              <form action="/menu/<%= item._id %>/delete" method="POST" onsubmit="return confirm('Delete this item?')">
                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
              </form>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% }) %>

<%- include('../partials/layout_end') %>
