<%- include('../partials/layout_start') %>

<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
  <% ['','pending','confirmed','checked_in','completed','cancelled','no_show'].forEach(s => { %>
  <a href="/bookings?status=<%= s %>" class="btn btn-sm <%= status===s?'btn-primary':'btn-outline-secondary' %>">
    <%= s ? s.replace(/_/g,' ').replace(/^\w/,c=>c.toUpperCase()) : 'All' %>
  </a>
  <% }) %>
  <a href="/bookings/new" class="btn btn-success btn-sm ms-auto"><i class="bi bi-calendar-plus me-1"></i>New Booking</a>
</div>

<% if (!bookings.length) { %>
<div class="text-center py-5 text-muted"><i class="bi bi-calendar-x fs-1"></i><div class="mt-2">No bookings found.</div></div>
<% } else { %>
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>Reference</th><th>Table</th><th>Start</th><th>End</th><th>Guests</th><th>Purpose</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% bookings.forEach(b => { %>
        <tr>
          <td class="fw-semibold small"><%= b.bookingReference %></td>
          <td><%= b.table?.tableNumber || b.tableNumber %> <small class="text-muted">(<%= b.table?.section||'' %>)</small></td>
          <td class="small"><%= new Date(b.startTime).toLocaleString([], {dateStyle:'short',timeStyle:'short'}) %></td>
          <td class="small"><%= new Date(b.endTime).toLocaleString([], {timeStyle:'short'}) %></td>
          <td><%= b.guestCount %></td>
          <td class="small text-muted"><%= b.purpose %></td>
          <td><%- include('../partials/status_badge', { status: b.status }) %></td>
          <td><a href="/bookings/<%= b._id %>" class="btn btn-sm btn-outline-primary">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% if (pages > 1) { %>
<nav class="mt-3"><ul class="pagination pagination-sm justify-content-center">
  <% for(let i=1;i<=pages;i++) { %><li class="page-item <%=page===i?'active':''%>"><a class="page-link" href="/bookings?page=<%= i %>&status=<%= status %>"><%= i %></a></li><% } %>
</ul></nav>
<% } %>
<% } %>

<%- include('../partials/layout_end') %>
