<%- include('../partials/layout_start') %>

<!-- Stats row -->
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-primary"><%= stats.deptStudentCount %></div>
      <div class="text-muted"><%= dept || 'Your' %> Students</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-success"><%= stats.attendanceMarked %></div>
      <div class="text-muted">Attendance Marked</div>
      <div class="small text-muted">last 7 days</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-info"><%= mySubjects.length %></div>
      <div class="text-muted">My Subjects</div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Quick actions -->
  <div class="col-md-6">
    <div class="row g-3">
      <div class="col-6"><a href="/smart-attendance/start-session" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-primary-subtle text-primary rounded-3 fs-4"><i class="bi bi-qr-code"></i></div><div><div class="fw-semibold">Smart Attendance</div><div class="small text-muted">QR + Face verification</div></div></div></a></div>
      <div class="col-6"><a href="/attendance/mark" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-info-subtle text-info rounded-3 fs-4"><i class="bi bi-person-check-fill"></i></div><div><div class="fw-semibold">Mark Attendance</div><div class="small text-muted">Manual attendance</div></div></div></a></div>
      <div class="col-6"><a href="/attendance/report" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-secondary-subtle text-secondary rounded-3 fs-4"><i class="bi bi-file-earmark-bar-graph"></i></div><div><div class="fw-semibold">Attendance Report</div><div class="small text-muted">View student data</div></div></div></a></div>
      <div class="col-6"><a href="/announcements/new" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-warning-subtle text-warning rounded-3 fs-4"><i class="bi bi-megaphone-fill"></i></div><div><div class="fw-semibold">Post Announcement</div><div class="small text-muted">Notify students</div></div></div></a></div>
      <div class="col-6"><a href="/orders/new" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-success-subtle text-success rounded-3 fs-4"><i class="bi bi-bag-plus"></i></div><div><div class="fw-semibold">Place Order</div><div class="small text-muted">Order from canteen</div></div></div></a></div>
      <div class="col-6"><a href="/chat" class="card border-0 shadow-sm text-decoration-none text-dark h-100 hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-success-subtle text-success rounded-3 fs-4"><i class="bi bi-chat-dots"></i></div><div><div class="fw-semibold">Chat Rooms</div><div class="small text-muted">Dept &amp; faculty chat</div></div></div></a></div>
    </div>
  </div>

  <!-- Semester breakdown chart -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-bar-chart-fill text-primary me-2"></i>
        <%= dept || 'Department' %> — Students per Semester
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <% if (semBreakdown.length) { %>
        <canvas id="semChart" style="max-height:200px"></canvas>
        <% } else { %>
        <div class="text-muted text-center">No semester data available</div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- My Assigned Subjects -->
<div class="row g-3 mb-3">
  <div class="col-md-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-book-half text-info me-2"></i>My Assigned Subjects
      </div>
      <% if (mySubjects.length) { %>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th class="ps-3">Code</th><th>Subject</th><th class="text-center">Sem</th></tr></thead>
            <tbody>
              <% mySubjects.forEach(s => { %>
              <tr>
                <td class="ps-3"><code class="text-primary"><%= s.code %></code></td>
                <td><%= s.name %></td>
                <td class="text-center"><span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle"><%= s.semester %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
      <% } else { %>
      <div class="card-body text-muted text-center py-4">
        <i class="bi bi-book fs-3 d-block mb-2 opacity-25"></i>
        No subjects assigned yet. Ask admin to assign subjects.
      </div>
      <% } %>
    </div>
  </div>

  <!-- Announcements -->
  <div class="col-md-5">
    <% if (announcements && announcements.length) { %>
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between pt-3">
        <span class="fw-semibold"><i class="bi bi-megaphone-fill text-warning me-1"></i>Recent Announcements</span>
        <a href="/announcements" class="btn btn-outline-secondary btn-sm">View All</a>
      </div>
      <div class="card-body p-0">
        <% announcements.forEach(function(ann) {
            var colMap = { info:'primary', warning:'warning', urgent:'danger' };
            var col    = colMap[ann.priority] || 'primary';
        %>
        <div class="d-flex gap-3 px-3 py-2 border-bottom align-items-start">
          <span class="badge bg-<%= col %>-subtle text-<%= col %> border border-<%= col %>-subtle mt-1 flex-shrink-0" style="font-size:.65rem"><%= ann.priority %></span>
          <div class="min-w-0 flex-grow-1">
            <div class="fw-semibold small"><%= ann.title %></div>
            <div class="text-muted small text-truncate"><%= ann.message.substring(0, 80) %><%= ann.message.length > 80 ? '…' : '' %></div>
            <div class="text-muted" style="font-size:.7rem"><%= new Date(ann.createdAt).toLocaleDateString() %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</div>

<% if (semBreakdown.length) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function() {
  const data = <%- JSON.stringify(semBreakdown) %>;
  new Chart(document.getElementById('semChart'), {
    type: 'bar',
    data: {
      labels: data.map(d => 'Sem ' + d._id),
      datasets: [{
        label: 'Students',
        data: data.map(d => d.count),
        backgroundColor: '#0d6efd',
        borderRadius: 5,
      }],
    },
    options: {
      plugins: { legend: { display: false } },
      scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
      responsive: true,
      maintainAspectRatio: true,
    },
  });
})();
</script>
<% } %>

<%- include('../partials/layout_end') %>
