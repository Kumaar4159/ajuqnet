<%- include('../partials/layout_start') %>
<!-- Welcome -->
<div class="mb-4">
  <h4 class="fw-bold mb-0">Welcome back, <%= user.name %> 👋</h4>
  <div class="text-muted small">Here's what's happening today</div>
</div>
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-warning"><%= stats.pendingOrders %></div>
      <div class="text-muted small">Pending Orders</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-primary"><%= stats.preparingOrders %></div>
      <div class="text-muted small">Preparing</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-success"><%= stats.readyOrders %></div>
      <div class="text-muted small">Ready for Pickup</div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-info"><%= stats.todayBookings %></div>
      <div class="text-muted small">Today's Bookings</div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6">
    <a href="/canteen/orders" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-warning-subtle text-warning rounded-3 fs-4"><i class="bi bi-bag-check-fill"></i></div>
        <div><div class="fw-semibold">Orders Queue</div><div class="small text-muted">View and update all active orders</div></div>
      </div>
    </a>
  </div>
  <div class="col-md-6">
    <a href="/canteen/bookings" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-info-subtle text-info rounded-3 fs-4"><i class="bi bi-calendar2-week-fill"></i></div>
        <div><div class="fw-semibold">Today's Bookings</div><div class="small text-muted">See who has reserved tables</div></div>
      </div>
    </a>
  </div>
</div>

<% if (recentOrders.length) { %>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
    <span class="fw-semibold"><i class="bi bi-lightning-charge-fill text-warning me-1"></i>Active Kitchen Queue</span>
    <a href="/canteen/orders" class="btn btn-outline-primary btn-sm">View All</a>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>Order #</th><th>Customer</th><th>Items</th><th>Total</th><th>Status</th><th>Time</th></tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(function(o) { %>
        <tr id="dash-row-<%= o._id %>">
          <td class="fw-semibold small"><%= o.orderNumber %></td>
          <td class="small"><%= o.placedByName %></td>
          <td class="small text-muted"><%= o.items.slice(0,2).map(i=>i.name+' ×'+i.quantity).join(', ') %><%= o.items.length>2?' …':'' %></td>
          <td class="small">₹<%= o.total.toFixed(2) %></td>
          <td id="dash-status-<%= o._id %>"><%- include('../partials/status_badge', { status: o.status }) %></td>
          <td class="small text-muted"><%= new Date(o.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } else { %>
<div class="text-center py-5 text-muted">
  <i class="bi bi-check-circle fs-1 text-success"></i>
  <div class="mt-2 fw-semibold">All caught up!</div>
  <div class="small">No active orders in the queue right now.</div>
</div>
<% } %>

<script src="/socket.io/socket.io.js"></script>
<script>
(function () {
  var colourMap = { pending:'warning', confirmed:'info', preparing:'primary', ready:'success', delivered:'secondary', cancelled:'danger' };
  function makeBadge(s) {
    return '<span class="badge bg-'+(colourMap[s]||'secondary')+'">'+s.charAt(0).toUpperCase()+s.slice(1)+'</span>';
  }
  var socket = io({ transports: ['websocket','polling'] });
  socket.on('order:statusUpdate', function (data) {
    var cell = document.getElementById('dash-status-' + data.orderId);
    if (cell) cell.innerHTML = makeBadge(data.status);
    if (['delivered','cancelled'].includes(data.status)) {
      var row = document.getElementById('dash-row-' + data.orderId);
      if (row) row.style.opacity = '0.4';
    }
  });
})();
</script>

<%- include('../partials/layout_end') %>
