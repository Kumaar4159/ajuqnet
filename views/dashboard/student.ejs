<%- include('../partials/layout_start') %>
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold <%= attendanceSummary && attendanceSummary.pct !== null && attendanceSummary.pct < 75 ? 'text-danger' : 'text-success' %>">
        <%= attendanceSummary && attendanceSummary.pct !== null ? attendanceSummary.pct + '%' : '—' %>
      </div>
      <div class="text-muted">Attendance</div>
      <% if (attendanceSummary && attendanceSummary.pct !== null && attendanceSummary.pct < 75) { %>
      <div class="small text-danger mt-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>Below 75%</div>
      <% } %>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-primary"><%= attendanceSummary ? attendanceSummary.present : 0 %></div>
      <div class="text-muted">Classes Attended</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-secondary"><%= attendanceSummary ? attendanceSummary.total : 0 %></div>
      <div class="text-muted">Total Classes</div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-6"><a href="/orders/new" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-success-subtle text-success rounded-3 fs-4"><i class="bi bi-bag-plus"></i></div><div><div class="fw-semibold">Place an Order</div><div class="small text-muted">Order from today's menu</div></div></div></a></div>
  <div class="col-md-6"><a href="/bookings/new" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-primary-subtle text-primary rounded-3 fs-4"><i class="bi bi-calendar-plus"></i></div><div><div class="fw-semibold">Book a Table</div><div class="small text-muted">Reserve your canteen spot</div></div></div></a></div>
  <div class="col-md-6"><a href="/attendance/view" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-info-subtle text-info rounded-3 fs-4"><i class="bi bi-person-check"></i></div><div><div class="fw-semibold">My Attendance</div><div class="small text-muted">View your attendance records</div></div></div></a></div>
  <div class="col-md-6"><a href="/chat" class="card border-0 shadow-sm text-decoration-none text-dark hover-lift"><div class="card-body d-flex align-items-center gap-3"><div class="stat-icon bg-warning-subtle text-warning rounded-3 fs-4"><i class="bi bi-chat-dots"></i></div><div><div class="fw-semibold">Chat Rooms</div><div class="small text-muted">Encrypted group & direct chat</div></div></div></a></div>
</div>

<!-- ── Attendance snapshot ─────────────────────────────────────────────────── -->
<% if (attendanceSummary && attendanceSummary.total > 0) { %>
<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
    <span class="fw-semibold"><i class="bi bi-person-check-fill text-primary me-1"></i>Attendance Overview</span>
    <a href="/attendance/view" class="btn btn-outline-primary btn-sm">Details</a>
  </div>
  <div class="card-body py-2">
    <div class="d-flex align-items-center gap-3">
      <div class="text-center" style="min-width:64px">
        <div class="fs-2 fw-bold <%= attendanceSummary.pct < 75 ? 'text-danger' : 'text-success' %>">
          <%= attendanceSummary.pct %>%
        </div>
        <div class="text-muted" style="font-size:.7rem">Overall</div>
      </div>
      <div class="flex-grow-1">
        <div class="progress" style="height:8px">
          <div class="progress-bar <%= attendanceSummary.pct >= 75 ? 'bg-success' : 'bg-danger' %>"
               style="width:<%= attendanceSummary.pct %>%"></div>
        </div>
        <div class="d-flex justify-content-between mt-1" style="font-size:.72rem">
          <span class="text-muted">
            <%= attendanceSummary.present %> present of <%= attendanceSummary.total %> classes
          </span>
          <% if (attendanceSummary.pct < 75) { %>
          <span class="text-danger fw-semibold">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>Below 75%
          </span>
          <% } else { %>
          <span class="text-success fw-semibold">
            <i class="bi bi-check-circle-fill me-1"></i>On Track
          </span>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- ── Latest announcements ────────────────────────────────────────────────── -->
<% if (announcements && announcements.length) { %>
<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
    <span class="fw-semibold"><i class="bi bi-megaphone-fill text-warning me-1"></i>Announcements</span>
    <a href="/announcements" class="btn btn-outline-secondary btn-sm">View All</a>
  </div>
  <div class="card-body p-0">
    <% announcements.forEach(function(ann) {
        var colMap = { info:'primary', warning:'warning', urgent:'danger' };
        var col    = colMap[ann.priority] || 'primary';
    %>
    <div class="d-flex gap-3 px-3 py-2 border-bottom align-items-start">
      <span class="badge bg-<%= col %>-subtle text-<%= col %> border border-<%= col %>-subtle mt-1 flex-shrink-0"
            style="font-size:.65rem">
        <%= ann.priority %>
      </span>
      <div class="min-w-0 flex-grow-1">
        <div class="fw-semibold small"><%= ann.pinned ? '📌 ' : '' %><%= ann.title %></div>
        <div class="text-muted small text-truncate">
          <%= ann.message.substring(0, 90) %><%= ann.message.length > 90 ? '…' : '' %>
        </div>
        <div class="text-muted" style="font-size:.7rem">
          <%= new Date(ann.createdAt).toLocaleDateString() %> · <%= ann.createdByName %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>
<% } %>

<!-- ── Recent orders ───────────────────────────────────────────────────────── -->
<% if (recentOrders.length) { %>
<div class="card border-0 shadow-sm">
  <div class="card-header bg-transparent border-0 fw-semibold">Recent Orders</div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>Order #</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr>
      </thead>
      <tbody>
        <% recentOrders.forEach(function(o) { %>
        <tr>
          <td class="fw-semibold small"><%= o.orderNumber %></td>
          <td class="small text-muted">
            <%= o.items.map(function(i){return i.name;}).join(', ').substring(0,40) %>
            <%= o.items.map(function(i){return i.name;}).join(', ').length > 40 ? '…' : '' %>
          </td>
          <td>₹<%= o.total.toFixed(2) %></td>
          <td><%- include('../partials/status_badge', { status: o.status }) %></td>
          <td><a href="/orders/<%= o._id %>" class="btn btn-sm btn-outline-secondary">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>
<%- include('../partials/layout_end') %>