<%- include('./partials/head') %>
<div class="auth-screen d-flex align-items-center justify-content-center min-vh-100">
  <div class="text-center">
    <div class="display-1 fw-bold text-primary mb-2"><%= code %></div>
    <h2 class="fw-bold mb-2"><%= title %></h2>
    <p class="text-muted mb-4"><%= message %></p>
    <% if (user) { %>
      <a href="/dashboard" class="btn btn-primary me-2"><i class="bi bi-house me-1"></i>Dashboard</a>
    <% } else { %>
      <a href="/auth/login" class="btn btn-primary me-2"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
    <% } %>
    <a href="javascript:history.back()" class="btn btn-outline-secondary">← Go Back</a>
  </div>
</div>
<%- include('./partials/footer') %>
