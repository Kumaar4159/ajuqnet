<%- include('../partials/head') %>
<div class="auth-screen d-flex align-items-center justify-content-center min-vh-100 py-4">
  <div class="auth-card card shadow-lg p-4" style="width:100%;max-width:460px">
    <div class="text-center mb-4">
      <div class="auth-logo mb-2"><i class="bi bi-person-plus-fill text-primary" style="font-size:2.5rem"></i></div>
      <h2 class="fw-bold mb-0">Create Account</h2>
      <p class="text-muted small">Join the campus system</p>
    </div>

    <% if (error) { %><div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= error %></div><% } %>

    <form action="/auth/register" method="POST">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label fw-semibold">Full Name</label>
          <input type="text" name="name" class="form-control" placeholder="Your full name" required minlength="2">
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Email</label>
          <input type="email" name="email" class="form-control" placeholder="you@school.edu" required>
        </div>
        <div class="col-12">
          <label class="form-label fw-semibold">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Min 8 characters" required minlength="8">
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Role</label>
          <select name="role" id="roleSelect" class="form-select">
            <option value="student">Student</option>
            <option value="faculty">Faculty</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Department</label>
          <select name="department" class="form-select">
            <option value="">Select department…</option>
            <option value="Computer Science">Computer Science (CS)</option>
            <option value="Electrical &amp; Electronics">Electrical &amp; Electronics (EEE)</option>
            <option value="Mechanical">Mechanical (MECH)</option>
          </select>
        </div>
        <div class="col-md-6" id="semesterField">
          <label class="form-label fw-semibold">Semester <span class="text-muted fw-normal">(students)</span></label>
          <select name="semester" class="form-select">
            <option value="">Select semester…</option>
            <% for(let i=1; i<=6; i++) { %><option value="<%= i %>">Semester <%= i %></option><% } %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Student ID <span class="text-muted fw-normal">(students only)</span></label>
          <input type="text" name="studentId" class="form-control" placeholder="e.g. CS2024001">
        </div>
        <div class="col-12 mt-2">
          <button type="submit" class="btn btn-primary w-100 fw-semibold">
            <i class="bi bi-person-check me-1"></i> Create Account
          </button>
        </div>
      </div>
    </form>
    <hr class="my-3">
    <p class="text-center mb-0 small">Already registered? <a href="/auth/login" class="fw-semibold">Sign in</a></p>
  </div>
</div>
<script>
  const roleSelect = document.getElementById('roleSelect');
  const semField   = document.getElementById('semesterField');
  roleSelect.addEventListener('change', function() {
    semField.style.display = this.value === 'student' ? '' : 'none';
  });
</script>
<%- include('../partials/footer') %>
