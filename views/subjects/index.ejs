<%- include('../partials/layout_start') %>

<div class="d-flex align-items-center gap-2 mb-4">
  <div class="stat-icon bg-info-subtle text-info rounded-3 fs-4"><i class="bi bi-book-half"></i></div>
  <div>
    <h5 class="mb-0 fw-bold">Subject Management</h5>
    <div class="text-muted small">Create subjects, assign faculty — faculty auto-loads their subjects when marking attendance</div>
  </div>
  <button class="btn btn-primary btn-sm ms-auto" data-bs-toggle="modal" data-bs-target="#createSubjectModal">
    <i class="bi bi-plus-lg me-1"></i>Add Subject
  </button>
</div>

<% if (typeof flash !== 'undefined' && flash && flash.success) { %>
<div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i><%= flash.success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>
<% if (typeof flash !== 'undefined' && flash && flash.error) { %>
<div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i><%= flash.error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<% } %>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-3">
    <form class="row g-3 align-items-end" method="GET" action="/subjects">
      <div class="col-sm-4">
        <label class="form-label fw-semibold small">Department</label>
        <select name="department" class="form-select form-select-sm">
          <option value="">All Departments</option>
          <% departments.forEach(d => { %><option value="<%= d %>" <%= filterDept===d?'selected':'' %>><%= d %></option><% }) %>
        </select>
      </div>
      <div class="col-sm-3">
        <label class="form-label fw-semibold small">Semester</label>
        <select name="semester" class="form-select form-select-sm">
          <option value="">All Semesters</option>
          <% semesters.forEach(s => { %><option value="<%= s %>" <%= filterSem===s?'selected':'' %>>Semester <%= s %></option><% }) %>
        </select>
      </div>
      <div class="col-sm-2">
        <button type="submit" class="btn btn-primary btn-sm w-100">Filter</button>
      </div>
      <div class="col-sm-2">
        <a href="/subjects" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
      </div>
    </form>
  </div>
</div>

<!-- Stats by dept -->
<div class="row g-3 mb-4">
  <% departments.forEach(dept => {
    const deptSubjects = subjects.filter(s => s.department===dept);
    const assigned = deptSubjects.filter(s => s.assignedFaculty).length;
    const total    = deptSubjects.length;
    if(total === 0 && filterDept && filterDept !== dept) return;
  %>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-2 fw-bold text-primary"><%= assigned %>/<%= total %></div>
      <div class="text-muted small"><%= dept %></div>
      <div class="text-muted" style="font-size:.75rem">subjects assigned</div>
    </div>
  </div>
  <% }) %>
</div>

<!-- Group by dept+semester -->
<% 
  const grouped = {};
  subjects.forEach(s => {
    const key = s.department + '||' + s.semester;
    if (!grouped[key]) grouped[key] = { dept: s.department, sem: s.semester, items: [] };
    grouped[key].items.push(s);
  });
  const groups = Object.values(grouped).sort((a,b) => a.dept.localeCompare(b.dept) || Number(a.sem)-Number(b.sem));
%>

<% if (groups.length === 0) { %>
<div class="card border-0 shadow-sm text-center py-5">
  <i class="bi bi-book fs-2 text-muted d-block mb-2 opacity-25"></i>
  <div class="text-muted">No subjects found. <button class="btn btn-link p-0" data-bs-toggle="modal" data-bs-target="#createSubjectModal">Add your first subject</button></div>
</div>
<% } %>

<% groups.forEach(g => { %>
<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-transparent border-0 d-flex align-items-center gap-2 pt-3">
    <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><%= g.dept %></span>
    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Semester <%= g.sem %></span>
    <span class="ms-auto text-muted small"><%= g.items.filter(i=>i.assignedFaculty).length %>/<%= g.items.length %> assigned</span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th class="ps-3" style="width:100px">Code</th>
            <th>Subject</th>
            <th>Assigned Faculty</th>
            <th style="width:200px">Change Assignment</th>
            <th style="width:50px"></th>
          </tr>
        </thead>
        <tbody>
          <% g.items.forEach(sub => { %>
          <tr>
            <td class="ps-3"><code class="text-primary"><%= sub.code %></code></td>
            <td class="fw-semibold"><%= sub.name %></td>
            <td>
              <% if (sub.assignedFaculty) { %>
                <span class="badge bg-success-subtle text-success border border-success-subtle">
                  <i class="bi bi-person-check me-1"></i><%= sub.assignedFacultyName %>
                </span>
              <% } else { %>
                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                  <i class="bi bi-person-x me-1"></i>Unassigned
                </span>
              <% } %>
            </td>
            <td>
              <form action="/subjects/<%= sub._id %>/assign" method="POST" class="d-flex gap-1">
                <select name="facultyId" class="form-select form-select-sm" style="max-width:160px">
                  <option value="">— Unassign —</option>
                  <% faculty.filter(f => f.department === sub.department).forEach(f => { %>
                  <option value="<%= f._id %>" <%= (sub.assignedFaculty && sub.assignedFaculty._id && sub.assignedFaculty._id.toString()===f._id.toString()) ? 'selected' : '' %>><%= f.name %></option>
                  <% }) %>
                  <% if (faculty.filter(f => f.department === sub.department).length === 0) { %>
                  <% faculty.forEach(f => { %>
                  <option value="<%= f._id %>" <%= (sub.assignedFaculty && sub.assignedFaculty._id && sub.assignedFaculty._id.toString()===f._id.toString()) ? 'selected' : '' %>><%= f.name %> (other dept)</option>
                  <% }) %>
                  <% } %>
                </select>
                <button type="submit" class="btn btn-sm btn-outline-primary px-2" title="Save"><i class="bi bi-check2"></i></button>
              </form>
            </td>
            <td>
              <form action="/subjects/<%= sub._id %>/delete" method="POST" onsubmit="return confirm('Delete subject <%= sub.code %> — <%= sub.name %>? This cannot be undone.')">
                <button type="submit" class="btn btn-sm btn-outline-danger px-2" title="Delete subject"><i class="bi bi-trash3"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% }) %>

<!-- ── Create Subject Modal ────────────────────────────────────────────── -->
<div class="modal fade" id="createSubjectModal" tabindex="-1" aria-labelledby="createSubjectLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="createSubjectLabel"><i class="bi bi-book-half me-2 text-info"></i>Add New Subject</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/subjects/create" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Subject Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" placeholder="e.g. Data Structures & Algorithms" required maxlength="100">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Subject Code <span class="text-danger">*</span></label>
            <input type="text" name="code" class="form-control text-uppercase" placeholder="e.g. CS301" required maxlength="20"
              oninput="this.value=this.value.toUpperCase()">
            <div class="form-text">Must be unique within the department.</div>
          </div>
          <div class="row g-3">
            <div class="col-sm-7">
              <label class="form-label fw-semibold">Department <span class="text-danger">*</span></label>
              <select name="department" class="form-select" required>
                <option value="">Select Department</option>
                <% departments.forEach(d => { %>
                <option value="<%= d %>"><%= d %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-sm-5">
              <label class="form-label fw-semibold">Semester <span class="text-danger">*</span></label>
              <select name="semester" class="form-select" required>
                <option value="">Select</option>
                <% semesters.forEach(s => { %>
                <option value="<%= s %>">Semester <%= s %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="alert alert-info mt-3 small py-2">
            <i class="bi bi-info-circle me-1"></i>
            After creating, go to the subject row and assign a faculty from the dropdown. Faculty will automatically see their assigned subjects when they select their department &amp; semester during attendance.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create Subject</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/layout_end') %>
