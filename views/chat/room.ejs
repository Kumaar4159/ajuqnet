<%- include('../partials/head') %>
<div class="app-wrapper">
  <!-- Sidebar: room list -->
  <nav id="sidebar" class="d-flex flex-column flex-shrink-0 p-0">
    <a href="/dashboard" class="sidebar-brand d-flex align-items-center gap-2 px-3 py-3 text-decoration-none">
      <i class="bi bi-mortarboard-fill fs-4"></i><span class="fw-bold">CampusSystem</span>
    </a>
    <hr class="sidebar-divider">
    <div class="px-2 py-1">
      <a href="/chat" class="btn btn-outline-secondary btn-sm w-100 mb-2"><i class="bi bi-arrow-left me-1"></i>All Rooms</a>
    </div>
    <div class="px-2 flex-grow-1 overflow-auto">
      <% allRooms.forEach(r => { %>
      <a href="/chat/room/<%= r._id %>" class="nav-link sidebar-link mb-1 <%= r._id.toString()===room._id.toString()?'active':'' %> d-flex justify-content-between align-items-center">
        <span class="text-truncate small">
          <% if (r.type==='direct') { %><i class="bi bi-person-fill me-1"></i><% } else if (r.type==='private') { %><i class="bi bi-lock-fill me-1"></i><% } else { %><i class="bi bi-hash me-1"></i><% } %>
          <%= r.name %>
        </span>
        <span class="online-dot d-none" id="online-<%= r._id %>"></span>
      </a>
      <% }) %>
    </div>
    <div class="sidebar-footer px-3 py-3 border-top">
      <div class="fw-semibold small text-truncate"><%= user.name %></div>
      <div class="sidebar-role badge"><%= user.role %></div>
    </div>
  </nav>

  <!-- Main chat area -->
  <div class="main-area d-flex flex-column flex-grow-1 overflow-hidden">
    <!-- Chat topbar -->
    <header class="topbar d-flex align-items-center px-3 gap-3">
      <button class="btn btn-sm btn-outline-secondary d-lg-none" id="sidebarToggle"><i class="bi bi-list fs-5"></i></button>
      <div>
        <span class="fw-bold"><%= room.name %></span>
        <% if (room.description) { %><span class="text-muted small ms-2"><%= room.description %></span><% } %>
      </div>
      <div class="ms-auto d-flex align-items-center gap-2">
        <span class="badge bg-success" id="onlineCount"><i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i><span id="onlineNum">...</span> online</span>
      </div>
    </header>

    <!-- Messages -->
    <div id="messages" class="flex-grow-1 overflow-auto px-3 py-2 d-flex flex-column gap-2">
      <% messages.forEach(msg => { %>
      <div class="chat-msg <%= msg.sender?.toString()===user.id||msg.sender?._id?.toString()===user.id?'own':'other' %>" id="msg-<%= msg._id %>">
        <% if (!msg.isDeleted) { %>
        <% if (msg.replyTo) { %>
        <div class="reply-snippet small text-muted mb-1 ps-2 border-start border-2">
          <strong><%= msg.replyTo.senderName %></strong>: <%= (msg.replyTo.content||'').substring(0,80) %>
        </div>
        <% } %>
        <div class="chat-bubble">
          <% if ((msg.sender?.toString()===user.id||msg.sender?._id?.toString()===user.id) === false) { %>
          <div class="chat-sender small fw-semibold text-primary mb-1"><%= msg.senderName %> <span class="badge bg-secondary" style="font-size:.6rem"><%= msg.senderRole %></span></div>
          <% } %>
          <div class="chat-text"><%= msg.content %><% if (msg.isEdited) { %> <span class="text-muted" style="font-size:.7rem">(edited)</span><% } %></div>
          <div class="chat-time"><%= new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></div>
        </div>
        <div class="chat-actions">
          <button class="btn btn-xs" onclick="setReply('<%= msg._id %>','<%= msg.senderName %>',`<%= (msg.content||'').replace(/`/g,'') %>`)">↩</button>
          <% if (msg.sender?.toString()===user.id||msg.sender?._id?.toString()===user.id) { %>
          <button class="btn btn-xs" onclick="editMsg('<%= msg._id %>',`<%= (msg.content||'').replace(/`/g,'').replace(/\n/g,' ') %>`)">✏️</button>
          <% } %>
          <% if (msg.sender?.toString()===user.id||user.role==='admin'||user.role==='faculty') { %>
          <button class="btn btn-xs text-danger del-btn" data-id="<%= msg._id %>" title="Delete">🗑</button>
          <% } %>
        </div>
        <% if (msg.reactions?.length) { %>
        <div class="chat-reactions mt-1">
          <% const rMap={}; msg.reactions.forEach(r=>{rMap[r.emoji]=(rMap[r.emoji]||0)+1;}); Object.entries(rMap).forEach(([e,c])=>{ %>
          <span class="reaction-chip" onclick="safeReact('<%= msg._id %>','<%= e %>')" title="React"><%= e %> <%= c %></span> e %> <%= c %></span>
          <% }) %>
        </div>
        <% } %>
        <% } else { %>
        <div class="chat-bubble deleted text-muted fst-italic small">🚫 Message deleted</div>
        <% } %>
      </div>
      <% }) %>
    </div>

    <!-- Typing indicator -->
    <div id="typingBar" class="px-3 py-1 text-muted small" style="min-height:1.5rem"></div>

    <!-- Reply preview -->
    <div id="replyPreview" class="d-none mx-3 mb-1 p-2 bg-light rounded small d-flex justify-content-between align-items-center">
      <span id="replyText" class="text-muted"></span>
      <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" onclick="clearReply()">×</button>
    </div>

    <!-- Input bar -->
    <div class="chat-input-bar px-3 py-2 border-top">
      <div class="d-flex gap-2 align-items-end">
        <div class="flex-grow-1 position-relative">
          <textarea id="msgInput" class="form-control" placeholder="Type a message… (Enter to send, Shift+Enter for newline)" rows="1" style="resize:none;max-height:120px;overflow-y:auto"></textarea>
        </div>
        <button class="btn btn-primary" id="sendBtn" onclick="sendMessage()"><i class="bi bi-send-fill"></i></button>
      </div>
      <div class="emoji-bar mt-1 d-flex gap-1">
        <% ['👍','❤️','😂','😮','😢','🎉'].forEach(e => { %><button type="button" class="btn btn-sm btn-light px-2 py-0" onclick="quickReact('<%= e %>')"><%= e %></button><% }) %>
        <span id="reactionTarget" class="d-none"></span>
      </div>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const ROOM_ID   = '<%= room._id %>';
const ME        = { id: '<%= user.id %>', name: '<%= user.name %>', role: '<%= user.role %>' };
let   replyToId = null;
let   editId    = null;
let   typingTimer;

const socket = io({ withCredentials: true });

socket.on('connect', () => {
  socket.emit('chat:join', { roomId: ROOM_ID });
});

socket.on('chat:members', ({ online }) => {
  document.getElementById('onlineNum').textContent = online.length;
});
socket.on('chat:online',  ({ name }) => { showSystem(name + ' joined'); });
socket.on('chat:offline', ({ name }) => { showSystem(name + ' left'); });

socket.on('chat:message', (msg) => { appendMessage(msg); scrollBottom(); });
socket.on('chat:message_edited', (msg) => { updateMessage(msg); });
socket.on('chat:message_deleted', ({ messageId }) => { markDeleted(messageId); });
socket.on('chat:reaction', ({ messageId, reactions }) => { updateReactions(messageId, reactions); });
socket.on('chat:typing', ({ name, isTyping }) => {
  document.getElementById('typingBar').textContent = isTyping ? name + ' is typing…' : '';
});
socket.on('chat:error', ({ message }) => { showToast(message, 'danger'); });

// Scroll to bottom on load
window.addEventListener('load', scrollBottom);

function scrollBottom() {
  const el = document.getElementById('messages');
  el.scrollTop = el.scrollHeight;
}

function sendMessage() {
  const input   = document.getElementById('msgInput');
  const content = input.value.trim();
  if (!content) return;

  if (editId) {
    socket.emit('chat:edit', { messageId: editId, newContent: content });
    editId = null;
    document.getElementById('sendBtn').innerHTML = '<i class="bi bi-send-fill"></i>';
  } else {
    socket.emit('chat:send', { roomId: ROOM_ID, content, replyToId });
  }
  input.value = '';
  clearReply();
  input.style.height = 'auto';
}

document.getElementById('msgInput').addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  socket.emit('chat:typing', { roomId: ROOM_ID, isTyping: true });
  clearTimeout(typingTimer);
  typingTimer = setTimeout(() => socket.emit('chat:typing', { roomId: ROOM_ID, isTyping: false }), 2000);
});
document.getElementById('msgInput').addEventListener('input', function() {
  this.style.height='auto'; this.style.height=Math.min(this.scrollHeight,120)+'px';
});

function esc(s) { const d=document.createElement('div'); d.textContent=s||''; return d.innerHTML; }

function appendMessage(msg) {
  const isOwn = (msg.sender?._id||msg.sender)?.toString() === ME.id;
  const div   = document.createElement('div');
  div.className = 'chat-msg ' + (isOwn ? 'own' : 'other');
  div.id = 'msg-' + msg._id;
  div.innerHTML = buildMsgHTML(msg, isOwn);
  document.getElementById('messages').appendChild(div);
  socket.emit('chat:read', { roomId: ROOM_ID, lastMessageId: msg._id });
}

function buildMsgHTML(msg, isOwn) {
  if (msg.isDeleted) return '<div class="chat-bubble deleted text-muted fst-italic small">🚫 Message deleted</div>';
  const reply = msg.replyTo ? `<div class="reply-snippet small text-muted mb-1 ps-2 border-start border-2"><strong>${esc(msg.replyTo.senderName)}</strong>: ${esc((msg.replyTo.content||'').substring(0,80))}</div>` : '';
  const sender = !isOwn ? `<div class="chat-sender small fw-semibold text-primary mb-1">${esc(msg.senderName)} <span class="badge bg-secondary" style="font-size:.6rem">${msg.senderRole}</span></div>` : '';
  const edited = msg.isEdited ? ' <span class="text-muted" style="font-size:.7rem">(edited)</span>' : '';
  const time   = new Date(msg.createdAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
  const canDel = isOwn || ME.role==='admin' || ME.role==='faculty';
  const canEdit = isOwn;
  const acts   = `<div class="chat-actions">
    <button class="btn btn-xs" onclick="setReply('${msg._id}','${esc(msg.senderName)}','${esc((msg.content||'').substring(0,60))}')">↩</button>
    ${canEdit ? `<button class="btn btn-xs" onclick="editMsg('${msg._id}',\`${(msg.content||'').replace(/`/g, '')}\`)">✏️</button>` : ''}
    ${canDel  ? `<button class="btn btn-xs text-danger del-btn" data-id="${msg._id}" title="Delete">🗑</button>` : ''}
  </div>`;
  return `${reply}<div class="chat-bubble">${sender}<div class="chat-text">${esc(msg.content)}${edited}</div><div class="chat-time">${time}</div></div>${acts}`;
}

function updateMessage(msg) {
  const el = document.getElementById('msg-' + msg._id);
  if (!el) return;
  const isOwn = (msg.sender?._id||msg.sender)?.toString() === ME.id;
  el.innerHTML = buildMsgHTML(msg, isOwn);
}

function markDeleted(id) {
  const el = document.getElementById('msg-' + id);
  if (el) el.innerHTML = '<div class="chat-bubble deleted text-muted fst-italic small">🚫 Message deleted</div>';
}

function updateReactions(msgId, reactions) {
  const msgEl = document.getElementById('msg-' + msgId);
  if (!msgEl) return;

  // Build a count map: { '👍': 2, '❤️': 1 }
  const rMap = {};
  reactions.forEach(r => { rMap[r.emoji] = (rMap[r.emoji] || 0) + 1; });

  // Find or create the reaction container on this message
  let reactDiv = msgEl.querySelector('.chat-reactions');
  if (Object.keys(rMap).length === 0) {
    if (reactDiv) reactDiv.remove();
    return;
  }
  if (!reactDiv) {
    reactDiv = document.createElement('div');
    reactDiv.className = 'chat-reactions mt-1';
    msgEl.appendChild(reactDiv);
  }

  // Re-render all chips
  reactDiv.innerHTML = Object.entries(rMap).map(([e, c]) =>
    `<span class="reaction-chip" onclick="safeReact('${msgId}','${e}')" title="React">${e} ${c}</span>`
  ).join('');
}
  // handled inline

function setReply(id, name, content) {
  replyToId = id;
  document.getElementById('replyText').textContent = name + ': ' + content.substring(0,60);
  document.getElementById('replyPreview').classList.remove('d-none');
  document.getElementById('msgInput').focus();
}
function clearReply() {
  replyToId = null;
  document.getElementById('replyPreview').classList.add('d-none');
}

function editMsg(id, content) {
  editId = id;
  const inp = document.getElementById('msgInput');
  inp.value = content;
  inp.focus();
  document.getElementById('sendBtn').innerHTML = '<i class="bi bi-pencil-fill"></i>';
}

// Event delegation for delete buttons (avoids onclick/CSP issues)
document.getElementById('messages').addEventListener('click', function(e) {
  var btn = e.target.closest('.del-btn');
  if (btn) {
    var id = btn.dataset.id;
    if (id && confirm('Delete this message?')) {
      socket.emit('chat:delete', { messageId: id });
    }
  }
});

function deleteMsg(id) {
  if (!confirm('Delete this message?')) return;
  socket.emit('chat:delete', { messageId: id });
}

function safeReact(messageId, emoji) {
  if (typeof socket !== 'undefined') socket.emit('chat:react', { messageId, emoji });
}

let lastReactId = null;
function quickReact(emoji) {
  if (!lastReactId) { showToast('Hover over a message first.', 'warning'); return; }
  socket.emit('chat:react', { messageId: lastReactId, emoji });
}

document.getElementById('messages').addEventListener('mouseover', e => {
  const msg = e.target.closest('.chat-msg');
  if (msg) lastReactId = msg.id.replace('msg-', '');
});

function showSystem(text) {
  const el = document.createElement('div');
  el.className = 'text-center text-muted small py-1';
  el.textContent = text;
  document.getElementById('messages').appendChild(el);
}

function showToast(msg, type='info') {
  const t = document.createElement('div');
  t.className = `alert alert-${type} alert-dismissible position-fixed top-0 end-0 m-3 shadow`;
  t.style.zIndex = 9999;
  t.innerHTML = msg + `<button type="button" class="btn-close" data-bs-dismiss="alert"></button>`;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 4000);
}

window.addEventListener('beforeunload', () => socket.emit('chat:leave', { roomId: ROOM_ID }));
</script>

<%- include('../partials/footer') %>
