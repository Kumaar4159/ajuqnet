<%- include('../partials/layout_start') %>
<div class="row justify-content-center">
  <div class="col-md-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold"><%= table ? 'Edit Table' : 'Add Table' %></div>
      <div class="card-body">
        <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>
        <form action="<%= table ? '/tables/'+table._id+'/update' : '/tables' %>" method="POST">
          <div class="row g-3">
            <% if (!table) { %>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Table Number *</label>
              <input type="text" name="tableNumber" class="form-control" placeholder="e.g. T-01" required>
            </div>
            <% } %>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Section *</label>
              <select name="section" class="form-select" required>
                <% ['indoor','outdoor','rooftop','private','cafeteria'].forEach(s => { %>
                  <option value="<%= s %>" <%=table?.section===s?'selected':''%>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Capacity *</label>
              <input type="number" name="capacity" class="form-control" min="1" max="30" value="<%= table?.capacity||4 %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Floor</label>
              <input type="number" name="floor" class="form-control" min="1" value="<%= table?.floor||1 %>">
            </div>
            <% if (table) { %>
            <div class="col-md-4">
              <div class="form-check mt-4">
                <input type="checkbox" name="isActive" class="form-check-input" id="active" value="1" <%=table.isActive?'checked':''%>>
                <label class="form-check-label" for="active">Active</label>
              </div>
            </div>
            <% } %>
            <div class="col-12">
              <label class="form-label fw-semibold">Description</label>
              <input type="text" name="description" class="form-control" value="<%= table?.description||'' %>" placeholder="Short description">
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Amenities</label>
              <div class="d-flex flex-wrap gap-2">
                <% ['ac','window_view','wheelchair_accessible','power_outlet','projector','whiteboard'].forEach(a => { %>
                <div class="form-check">
                  <input type="checkbox" name="amenities" class="form-check-input" id="a_<%= a %>" value="<%= a %>" <%=(table?.amenities||[]).includes(a)?'checked':''%>>
                  <label class="form-check-label small" for="a_<%= a %>"><%= a.replace(/_/g,' ') %></label>
                </div>
                <% }) %>
              </div>
            </div>
            <div class="col-12 d-flex gap-2 mt-2">
              <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i><%= table ? 'Save Changes' : 'Add Table' %></button>
              <a href="/tables" class="btn btn-outline-secondary">Cancel</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/layout_end') %>
