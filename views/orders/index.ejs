<%- include('../partials/layout_start') %>

<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
  <% ['','pending','confirmed','preparing','ready','delivered','cancelled'].forEach(s => { %>
  <a href="/orders?status=<%= s %>" class="btn btn-sm <%= status===s ? 'btn-primary' : 'btn-outline-secondary' %>">
    <%= s ? s.charAt(0).toUpperCase()+s.slice(1) : 'All' %>
  </a>
  <% }) %>
  <a href="/orders/new" class="btn btn-success btn-sm ms-auto"><i class="bi bi-bag-plus me-1"></i>New Order</a>
</div>

<% if (orders.length === 0) { %>
  <div class="text-center py-5 text-muted"><i class="bi bi-bag fs-1"></i><div class="mt-2">No orders found.</div></div>
<% } else { %>
<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr><th>Order #</th><th>Items</th><th>Total</th><th>Status</th><th>Date</th><th></th></tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
        <tr>
          <td class="fw-semibold small"><%= o.orderNumber %></td>
          <td class="small text-muted"><%= o.items.slice(0,2).map(i=>i.name+' ×'+i.quantity).join(', ') %><%= o.items.length>2 ? ' …' : '' %></td>
          <td class="fw-semibold">₹<%= o.total.toFixed(2) %></td>
          <td><%- include('../partials/status_badge', { status: o.status }) %></td>
          <td class="small text-muted"><%= new Date(o.createdAt).toLocaleDateString() %></td>
          <td><a href="/orders/<%= o._id %>" class="btn btn-sm btn-outline-primary">View</a></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<!-- Pagination -->
<% if (pages > 1) { %>
<nav class="mt-3"><ul class="pagination pagination-sm justify-content-center">
  <% for(let i=1;i<=pages;i++) { %><li class="page-item <%=page===i?'active':''%>"><a class="page-link" href="/orders?page=<%= i %>&status=<%= status %>"><%= i %></a></li><% } %>
</ul></nav>
<% } %>
<% } %>

<script src="/socket.io/socket.io.js"></script>
<script>
(function () {
  var colourMap = {
    pending: 'warning', confirmed: 'info', preparing: 'primary',
    ready: 'success', delivered: 'secondary', cancelled: 'danger',
  };

  function makeBadge(status) {
    var cls = colourMap[status] || 'secondary';
    var label = status.charAt(0).toUpperCase() + status.slice(1);
    return '<span class="badge bg-' + cls + '">' + label + '</span>';
  }

  var socket = io({ transports: ['websocket', 'polling'] });

  socket.on('order:statusUpdate', function (data) {
    var link = document.querySelector('a[href="/orders/' + data.orderId + '"]');
    if (!link) return;

    var row = link.closest('tr');
    if (!row) return;

    var statusCell = row.querySelectorAll('td')[3];
    if (statusCell) statusCell.innerHTML = makeBadge(data.status);

    row.style.transition = 'background .3s';
    row.style.background = 'rgba(59,130,246,.12)';
    setTimeout(function () { row.style.background = ''; }, 2000);
  });
})();
</script>

<%- include('../partials/layout_end') %>