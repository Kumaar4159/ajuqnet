<%- include('../partials/layout_start') %>

<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<form action="/orders" method="POST" id="orderForm">
  <input type="hidden" name="items" id="itemsJson">

  <div class="row g-3">
    <!-- Menu selector -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 fw-semibold">Select Items</div>
        <div class="card-body" style="max-height:520px;overflow-y:auto">
          <% const cats = Object.keys(grouped); %>
          <% cats.forEach(cat => { %>
          <h6 class="text-uppercase text-muted small mt-3 mb-2"><%= cat %></h6>
          <% grouped[cat].forEach(item => { %>
          <div class="menu-row d-flex align-items-center gap-2 py-2 border-bottom">
            <div class="flex-grow-1">
              <span class="fw-semibold"><%= item.name %></span>
              <% if (item.isVegetarian) { %><span class="text-success ms-1">🟢</span><% } %>
              <br><small class="text-muted"><%= item.description?.substring(0,50) || '' %></small>
              <% if (item.stock !== null) { %><small class="text-warning ms-2">(Stock: <%= item.stock %>)</small><% } %>
            </div>
            <span class="fw-bold text-primary me-2">₹<%= item.price %></span>
            <div class="qty-controls d-flex align-items-center gap-1">
              <button type="button" class="btn btn-sm btn-outline-secondary px-2 qty-btn" data-id="<%= item._id %>" data-delta="-1">−</button>
              <span class="qty-val fw-bold mx-1" id="qty-<%= item._id %>" data-id="<%= item._id %>" data-name="<%= item.name.replace(/"/g,'&quot;').replace(/'/g,'&#39;') %>" data-price="<%= item.price %>">0</span>
              <button type="button" class="btn btn-sm btn-outline-secondary px-2 qty-btn" data-id="<%= item._id %>" data-delta="1">+</button>
            </div>
          </div>
          <% }) %>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Order summary -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm position-sticky" style="top:1rem">
        <div class="card-header bg-transparent border-0 fw-semibold">Order Summary</div>
        <div class="card-body">
          <div id="summaryItems" class="mb-3 text-muted small">No items added yet.</div>
          <hr>
          <div class="d-flex justify-content-between small"><span>Subtotal</span><span id="subtotal">₹0.00</span></div>
          <div class="d-flex justify-content-between small text-muted"><span>Tax (5%)</span><span id="tax">₹0.00</span></div>
          <div class="d-flex justify-content-between fw-bold mt-1"><span>Total</span><span id="total" class="text-primary">₹0.00</span></div>
          <div class="mt-3">
            <label class="form-label small fw-semibold">Delivery Location</label>
            <input type="text" name="deliveryLocation" class="form-control form-control-sm" placeholder="e.g. Room 201">
          </div>
          <div class="mt-2">
            <label class="form-label small fw-semibold">Notes</label>
            <textarea name="notes" class="form-control form-control-sm" rows="2" placeholder="Special instructions..."></textarea>
          </div>
          <button type="submit" class="btn btn-success w-100 mt-3 fw-semibold" id="placeBtn" disabled>
            <i class="bi bi-bag-check me-1"></i>Place Order
          </button>
          <a href="/menu" class="btn btn-outline-secondary w-100 mt-2 btn-sm">Back to Menu</a>
        </div>
      </div>
    </div>
  </div>
</form>

<script>
const cart = {};

document.addEventListener('click', function(e) {
  const btn = e.target.closest('.qty-btn');
  if (!btn) return;
  const id    = btn.dataset.id;
  const delta = parseInt(btn.dataset.delta);
  const el    = document.getElementById('qty-'+id);
  const cur   = parseInt(el.textContent) || 0;
  const nxt   = Math.max(0, cur + delta);
  el.textContent = nxt;
  if (nxt === 0) delete cart[id];
  else cart[id] = { menuItemId: id, quantity: nxt, name: el.dataset.name, price: parseFloat(el.dataset.price) };
  updateSummary();
});

function updateSummary() {
  const items = Object.values(cart);
  const sub   = items.reduce((s, i) => s + i.price * i.quantity, 0);
  const tax   = sub * 0.05;
  document.getElementById('subtotal').textContent = '₹'+sub.toFixed(2);
  document.getElementById('tax').textContent      = '₹'+tax.toFixed(2);
  document.getElementById('total').textContent    = '₹'+(sub+tax).toFixed(2);
  document.getElementById('placeBtn').disabled    = items.length === 0;
  const si = document.getElementById('summaryItems');
  if (!items.length) { si.textContent = 'No items added yet.'; return; }
  si.innerHTML = items.map(i=>`<div class="d-flex justify-content-between"><span>${i.name} ×${i.quantity}</span><span>₹${(i.price*i.quantity).toFixed(2)}</span></div>`).join('');
}
document.getElementById('orderForm').addEventListener('submit', e => {
  document.getElementById('itemsJson').value = JSON.stringify(Object.values(cart).map(i=>({ menuItemId: i.menuItemId, quantity: i.quantity })));
  if (!Object.keys(cart).length) { e.preventDefault(); alert('Please add at least one item.'); }
});
</script>
<%- include('../partials/layout_end') %>
