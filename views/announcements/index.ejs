<%- include('../partials/layout_start') %>

<% if (success) { %>
<div class="alert alert-success alert-dismissible fade show py-2 small mb-3">
  <i class="bi bi-check-circle-fill me-1"></i><%= success %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>
<% if (error) { %>
<div class="alert alert-danger alert-dismissible fade show py-2 small mb-3">
  <i class="bi bi-exclamation-triangle-fill me-1"></i><%= error %>
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
  <div>
    <h5 class="mb-0 fw-bold"><i class="bi bi-megaphone-fill text-primary me-2"></i>Announcements</h5>
    <div class="text-muted small"><%= announcements.length %> active announcement(s)</div>
  </div>
  <% if (canCreate) { %>
  <a href="/announcements/new" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>New Announcement
  </a>
  <% } %>
</div>

<% if (!announcements.length) { %>
<div class="card border-0 shadow-sm">
  <div class="card-body text-center py-5 text-muted">
    <i class="bi bi-megaphone fs-1 d-block mb-2 opacity-25"></i>
    No announcements at the moment. Check back later.
  </div>
</div>
<% } else { %>
<div class="d-flex flex-column gap-3">
  <% announcements.forEach(function(ann) {
      var colorMap = { info:'primary', warning:'warning', urgent:'danger' };
      var iconMap  = { info:'bi-info-circle-fill', warning:'bi-exclamation-triangle-fill', urgent:'bi-megaphone-fill' };
      var col = colorMap[ann.priority] || 'primary';
      var ico = iconMap[ann.priority]  || 'bi-info-circle-fill';
  %>
  <div class="card border-0 shadow-sm"
       style="border-left:4px solid var(--bs-<%= col %>) !important">
    <div class="card-body">
      <div class="d-flex align-items-start gap-3">
        <div class="flex-shrink-0 mt-1">
          <span class="badge bg-<%= col %>-subtle text-<%= col %> border border-<%= col %>-subtle rounded-circle p-2">
            <i class="bi <%= ico %>"></i>
          </span>
        </div>
        <div class="flex-grow-1 min-w-0">
          <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
            <span class="fw-bold">
              <% if (ann.pinned) { %><i class="bi bi-pin-angle-fill text-warning me-1"></i><% } %>
              <%= ann.title %>
            </span>
            <span class="badge bg-<%= col %>-subtle text-<%= col %> border border-<%= col %>-subtle"
                  style="font-size:.65rem">
              <%= ann.priority.charAt(0).toUpperCase() + ann.priority.slice(1) %>
            </span>
            <% if (ann.department !== 'all') { %>
            <span class="badge bg-secondary-subtle text-secondary" style="font-size:.65rem">
              <i class="bi bi-building me-1"></i><%= ann.department %>
            </span>
            <% } %>
          </div>
          <p class="mb-2 text-muted small" style="white-space:pre-wrap"><%= ann.message %></p>
          <% if (ann.attachment && ann.attachment.filename) { %>
          <a href="/announcements/<%= ann._id %>/attachment" class="btn btn-outline-primary btn-sm mb-2" download>
            <i class="bi bi-paperclip me-1"></i><%= ann.attachment.filename %>
            <span class="text-muted ms-1 small">(<%= ann.attachment.size ? (ann.attachment.size/1024).toFixed(1)+'KB' : '' %>)</span>
          </a>
          <% } %>
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="small text-muted">
              <i class="bi bi-person-circle me-1"></i><%= ann.createdByName %>
              <span class="badge bg-secondary-subtle text-secondary ms-1"><%= ann.createdByRole %></span>
              <span class="ms-2">
                <i class="bi bi-clock me-1"></i>
                <%= new Date(ann.createdAt).toLocaleDateString([], {year:'numeric',month:'short',day:'numeric'}) %>
              </span>
            </div>
            <% if (canCreate) { %>
            <form action="/announcements/<%= ann._id %>/delete" method="POST"
                  onsubmit="return confirm('Delete this announcement?')">
              <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2"
                      style="font-size:.72rem">
                <i class="bi bi-trash3"></i>
              </button>
            </form>
            <% } %>
          </div>
          <% if (ann.expiresAt) { %>
          <div class="small text-muted mt-1">
            <i class="bi bi-calendar-x me-1"></i>Expires: <%= new Date(ann.expiresAt).toLocaleDateString() %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
</div>
<% } %>

<style>
.card[style*="border-left"] { transition: box-shadow .15s, transform .15s; }
.card[style*="border-left"]:hover { box-shadow: 0 4px 20px rgba(0,0,0,.1) !important; transform: translateY(-1px); }
</style>

<%- include('../partials/layout_end') %>