<%- include('../partials/layout_start') %>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
  <div class="d-flex align-items-center gap-2">
    <div class="stat-icon bg-info-subtle text-info rounded-3 fs-4">
      <i class="bi bi-people-fill"></i>
    </div>
    <div>
      <h5 class="mb-0 fw-bold"><%= session.subject %></h5>
      <div class="text-muted small">
        <%= session.department %> · <%= session.semester %> · <%= session.room %> ·
        <%= new Date(session.startTime).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
      </div>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="/smart-attendance/my-sessions" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-arrow-left me-1"></i>All Sessions
    </a>
    <% if (session.status === 'active' && !session.isExpired) { %>
    <a href="/smart-attendance/qr/<%= session._id %>" class="btn btn-primary btn-sm">
      <i class="bi bi-qr-code me-1"></i>View Live QR
    </a>
    <% } %>
  </div>
</div>

<!-- ── Summary cards ─────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-success"><%= analytics.present %></div>
      <div class="text-muted small">Present</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-danger"><%= analytics.total - analytics.present %></div>
      <div class="text-muted small">Absent / Rejected</div>
    </div>
  </div>
  <div class="col-sm-4">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold <%= analytics.pct < 75 ? 'text-danger' : 'text-primary' %>">
        <%= analytics.pct %>%
      </div>
      <div class="text-muted small">Attendance Rate</div>
    </div>
  </div>
</div>

<div class="row g-4">

  <!-- Present/Absent list -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between pt-3">
        <span class="fw-semibold"><i class="bi bi-list-check text-primary me-1"></i>Attendance List</span>
        <!-- Search -->
        <input type="text" id="studentSearch" class="form-control form-control-sm" style="max-width:160px" placeholder="Search name…">
      </div>
      <% if (analytics.records.length === 0) { %>
      <div class="card-body text-center text-muted py-4">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>No students have attempted attendance yet.
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0" id="attendanceTable">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Student</th>
              <th>Status</th>
              <th>Face</th>
              <th>Location</th>
              <th>Distance</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% analytics.records.forEach(function(rec) { %>
            <tr class="student-row">
              <td class="ps-3">
                <div class="fw-semibold small"><%= rec.studentName %></div>
                <div class="text-muted" style="font-size:.7rem"><%= rec.studentId?.studentId || '' %></div>
              </td>
              <td>
                <% if (rec.status === 'present') { %>
                <span class="badge bg-success-subtle text-success border border-success-subtle">Present</span>
                <% } else { %>
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Rejected</span>
                <% } %>
              </td>
              <td>
                <% if (rec.verificationType.face) { %>
                <i class="bi bi-check-circle-fill text-success"></i>
                <% } else { %>
                <i class="bi bi-x-circle-fill text-danger"></i>
                <% } %>
              </td>
              <td>
                <% if (rec.verificationType.location) { %>
                <i class="bi bi-check-circle-fill text-success"></i>
                <% } else { %>
                <i class="bi bi-x-circle-fill text-danger"></i>
                <% } %>
              </td>
              <td class="small text-muted">
                <%= rec.distanceMetres != null ? rec.distanceMetres + 'm' : '—' %>
              </td>
              <td class="small text-muted">
                <%= new Date(rec.timestamp).toLocaleTimeString('en-IN', {hour:'2-digit',minute:'2-digit'}) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Chart panel -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-pie-chart-fill text-warning me-1"></i> Attendance Breakdown
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <% if (analytics.total === 0) { %>
        <div class="text-center text-muted py-3">No data yet.</div>
        <% } else { %>
        <canvas id="sessionDoughnut" style="max-height:220px"></canvas>
        <% } %>
      </div>
    </div>

    <!-- Session info -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-info-circle text-info me-1"></i> Session Info
      </div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <tbody>
            <tr><td class="text-muted ps-3">Faculty</td><td class="fw-semibold"><%= session.facultyName %></td></tr>
            <tr><td class="text-muted ps-3">Duration</td><td class="fw-semibold"><%= session.durationMinutes %> min</td></tr>
            <tr>
              <td class="text-muted ps-3">Status</td>
              <td>
                <% if (session.isExpired || session.status === 'closed') { %>
                <span class="badge bg-secondary">Closed</span>
                <% } else { %>
                <span class="badge bg-success">Active</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td class="text-muted ps-3">GPS Check</td>
              <td>
                <% if (session.teacherLocation && session.teacherLocation.lat) { %>
                <span class="text-success small"><i class="bi bi-geo-alt-fill"></i> Enabled</span>
                <% } else { %>
                <span class="text-muted small">Disabled</span>
                <% } %>
              </td>
            </tr>
            <tr>
              <td class="text-muted ps-3">Radius</td>
              <td class="text-muted small">100 metres</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<% if (analytics.total > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const isDark = document.body.classList.contains('dark-mode');
  Chart.defaults.color = isDark ? '#94a3b8' : '#64748b';

  new Chart(document.getElementById('sessionDoughnut'), {
    type: 'doughnut',
    data: {
      labels: ['Present', 'Rejected'],
      datasets: [{
        data: [<%= analytics.present %>, <%= analytics.total - analytics.present %>],
        backgroundColor: ['#22c55e', '#ef4444'],
        borderWidth: 2,
        borderColor: isDark ? '#1e293b' : '#fff',
      }],
    },
    options: {
      responsive: true,
      cutout: '65%',
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16 } },
      },
    },
  });
</script>
<% } %>

<script>
  // Table search
  document.getElementById('studentSearch')?.addEventListener('input', function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.student-row').forEach(function (row) {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });
</script>

<%- include('../partials/layout_end') %>
