<%- include('../partials/layout_start') %>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
  <div class="d-flex align-items-center gap-2">
    <div class="stat-icon bg-success-subtle text-success rounded-3 fs-4">
      <i class="bi bi-bar-chart-fill"></i>
    </div>
    <div>
      <h5 class="mb-0 fw-bold">My Smart Attendance</h5>
      <div class="text-muted small">Face + GPS verified attendance analytics</div>
    </div>
  </div>
  <a href="/smart-attendance/scan" class="btn btn-primary btn-sm">
    <i class="bi bi-qr-code-scan me-1"></i>Scan Attendance QR
  </a>
</div>

<% const pct = analytics.pct; %>

<!-- ── Summary cards ─────────────────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold <%= pct !== null && pct < 75 ? 'text-danger' : 'text-success' %>">
        <%= pct !== null ? pct + '%' : 'N/A' %>
      </div>
      <div class="text-muted small">Overall Attendance</div>
      <% if (pct !== null && pct < 75) { %>
      <div class="text-danger small fw-semibold mt-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>Below 75%</div>
      <% } %>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-primary"><%= analytics.present %></div>
      <div class="text-muted small">Classes Present</div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-warning"><%= analytics.total - analytics.present %></div>
      <div class="text-muted small">Classes Missed</div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-info"><%= analytics.subjects.length %></div>
      <div class="text-muted small">Subjects</div>
    </div>
  </div>
</div>

<% if (pct !== null && pct < 75) { %>
<div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
  <i class="bi bi-exclamation-triangle-fill fs-4"></i>
  <div>
    <strong>Attendance Warning!</strong> Your overall attendance is <%= pct %>%, which is below the minimum 75% requirement.
    You need to attend more classes to avoid academic consequences.
  </div>
</div>
<% } %>

<div class="row g-4">

  <!-- Subject-wise breakdown -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-book-fill text-primary me-1"></i> Subject-wise Attendance
      </div>
      <div class="card-body">
        <% if (analytics.subjects.length === 0) { %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-inbox fs-1 d-block mb-2"></i>No attendance records yet.
        </div>
        <% } else { %>
        <% analytics.subjects.forEach(function(s) { %>
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold small"><%= s.name %></span>
            <span class="small <%= s.pct < 75 ? 'text-danger fw-bold' : 'text-success fw-bold' %>">
              <%= s.pct %>% (<%= s.present %>/<%= s.total %>)
            </span>
          </div>
          <div class="progress" style="height:8px">
            <div class="progress-bar <%= s.pct >= 75 ? 'bg-success' : s.pct >= 60 ? 'bg-warning' : 'bg-danger' %>"
                 style="width:<%= s.pct %>%"></div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Doughnut chart -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-pie-chart-fill text-warning me-1"></i> Subject Distribution
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <% if (analytics.subjects.length === 0) { %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-bar-chart fs-1 d-block mb-2"></i>No data yet.
        </div>
        <% } else { %>
        <canvas id="subjectDoughnut" style="max-height:280px"></canvas>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 30-day trend chart -->
  <div class="col-12">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-graph-up text-info me-1"></i> 30-Day Attendance Trend
      </div>
      <div class="card-body">
        <% if (analytics.trend.length === 0) { %>
        <div class="text-center text-muted py-4">
          <i class="bi bi-graph-up fs-1 d-block mb-2"></i>No trend data yet.
        </div>
        <% } else { %>
        <canvas id="trendChart" style="height:200px"></canvas>
        <% } %>
      </div>
    </div>
  </div>

</div>

<% if (analytics.subjects.length > 0 || analytics.trend.length > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
  const isDark = document.body.classList.contains('dark-mode');
  const textColor = isDark ? '#94a3b8' : '#64748b';
  const gridColor = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)';

  Chart.defaults.color = textColor;
  Chart.defaults.borderColor = gridColor;

  <% if (analytics.subjects.length > 0) { %>
  // Doughnut
  const palette = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316','#ec4899'];
  new Chart(document.getElementById('subjectDoughnut'), {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(analytics.subjects.map(s => s.name)) %>,
      datasets: [{
        data:            <%- JSON.stringify(analytics.subjects.map(s => s.present)) %>,
        backgroundColor: palette.slice(0, <%- analytics.subjects.length %>),
        borderWidth:     2,
        borderColor:     isDark ? '#1e293b' : '#ffffff',
      }],
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16 } },
        tooltip: {
          callbacks: {
            label: ctx => ' ' + ctx.label + ': ' + ctx.raw + ' classes present',
          },
        },
      },
      cutout: '65%',
    },
  });
  <% } %>

  <% if (analytics.trend.length > 0) { %>
  // Trend line
  const trendLabels = <%- JSON.stringify(analytics.trend.map(t => t._id)) %>;
  const trendPresent = <%- JSON.stringify(analytics.trend.map(t => t.present)) %>;
  new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
      labels: trendLabels,
      datasets: [{
        label:           'Classes Attended',
        data:            trendPresent,
        borderColor:     '#3b82f6',
        backgroundColor: 'rgba(59,130,246,.15)',
        pointBackgroundColor: '#3b82f6',
        fill:            true,
        tension:         0.4,
        pointRadius:     4,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: { grid: { display: false } },
        y: { beginAtZero: true, ticks: { stepSize: 1 } },
      },
      plugins: { legend: { display: false } },
    },
  });
  <% } %>
}());
</script>
<% } %>

<%- include('../partials/layout_end') %>
