<%- include('../partials/layout_start') %>

<div class="d-flex align-items-center gap-2 mb-4">
  <div class="stat-icon bg-warning-subtle text-warning rounded-3 fs-4">
    <i class="bi bi-graph-up-arrow"></i>
  </div>
  <div>
    <h5 class="mb-0 fw-bold">Smart Attendance Analytics</h5>
    <div class="text-muted small">System-wide attendance statistics</div>
  </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-primary"><%= totalSessions %></div>
      <div class="text-muted small">Total Sessions</div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-info"><%= totalRecords %></div>
      <div class="text-muted small">Attendance Attempts</div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold text-success"><%= presentCount %></div>
      <div class="text-muted small">Marked Present</div>
    </div>
  </div>
  <div class="col-sm-3">
    <div class="card border-0 shadow-sm text-center py-3">
      <div class="fs-1 fw-bold <%= overallPct < 75 ? 'text-danger' : 'text-success' %>"><%= overallPct %>%</div>
      <div class="text-muted small">Overall Pass Rate</div>
    </div>
  </div>
</div>

<div class="row g-4">

  <!-- Department bar chart -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-building text-primary me-1"></i> Department-wise Attendance
      </div>
      <div class="card-body">
        <% if (deptStats.length === 0) { %>
        <div class="text-center text-muted py-4"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No data yet.</div>
        <% } else { %>
        <!-- Progress bars -->
        <% deptStats.forEach(function(d) {
          const pct = d.total > 0 ? Math.round(d.present / d.total * 100) : 0;
        %>
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold small"><%= d._id %></span>
            <span class="small <%= pct < 75 ? 'text-danger fw-bold' : 'text-success fw-bold' %>">
              <%= pct %>% (<%= d.present %>/<%= d.total %>)
            </span>
          </div>
          <div class="progress" style="height:10px">
            <div class="progress-bar <%= pct >= 75 ? 'bg-success' : pct >= 60 ? 'bg-warning' : 'bg-danger' %>"
                 style="width:<%= pct %>%"></div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Dept doughnut -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-pie-chart-fill text-warning me-1"></i> Department Distribution
      </div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <% if (deptStats.length === 0) { %>
        <div class="text-center text-muted py-3">No data.</div>
        <% } else { %>
        <canvas id="deptDoughnut" style="max-height:240px"></canvas>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 14-day trend -->
  <div class="col-12">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-calendar-range text-info me-1"></i> 14-Day Daily Attendance Trend
      </div>
      <div class="card-body">
        <% if (dailyTrend.length === 0) { %>
        <div class="text-center text-muted py-4"><i class="bi bi-graph-up fs-1 d-block mb-2"></i>No data yet.</div>
        <% } else { %>
        <canvas id="dailyTrendChart" style="height:220px"></canvas>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Today's sessions -->
  <div class="col-12">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent border-0 fw-semibold pt-3">
        <i class="bi bi-calendar-check text-success me-1"></i> Today's Sessions
      </div>
      <% if (todaySessions.length === 0) { %>
      <div class="card-body text-center text-muted py-4">No sessions started today.</div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Faculty</th>
              <th>Subject</th>
              <th>Department</th>
              <th>Room</th>
              <th>Started</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% todaySessions.forEach(function(s) { %>
            <tr>
              <td class="ps-3 small fw-semibold"><%= s.facultyName %></td>
              <td class="small"><%= s.subject %></td>
              <td class="text-muted small"><%= s.department %></td>
              <td class="text-muted small"><%= s.room %></td>
              <td class="text-muted small"><%= new Date(s.startTime).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %></td>
              <td>
                <% if (s.status === 'active') { %>
                <span class="badge bg-success-subtle text-success border border-success-subtle">Active</span>
                <% } else { %>
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle">Closed</span>
                <% } %>
              </td>
              <td>
                <a href="/smart-attendance/faculty-report/<%= s._id %>" class="btn btn-xs btn-outline-secondary">
                  <i class="bi bi-bar-chart"></i>
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>

<% if (deptStats.length > 0 || dailyTrend.length > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
(function () {
  const isDark = document.body.classList.contains('dark-mode');
  Chart.defaults.color = isDark ? '#94a3b8' : '#64748b';
  Chart.defaults.borderColor = isDark ? 'rgba(255,255,255,.07)' : 'rgba(0,0,0,.06)';

  <% if (deptStats.length > 0) { %>
  const palette = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#f97316'];
  new Chart(document.getElementById('deptDoughnut'), {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(deptStats.map(d => d._id)) %>,
      datasets: [{
        data: <%- JSON.stringify(deptStats.map(d => d.total)) %>,
        backgroundColor: palette.slice(0, <%= deptStats.length %>),
        borderWidth: 2,
        borderColor: isDark ? '#1e293b' : '#fff',
      }],
    },
    options: {
      responsive: true,
      cutout: '60%',
      plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 14 } } },
    },
  });
  <% } %>

  <% if (dailyTrend.length > 0) { %>
  new Chart(document.getElementById('dailyTrendChart'), {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(dailyTrend.map(d => d._id)) %>,
      datasets: [
        {
          label: 'Present',
          data:  <%- JSON.stringify(dailyTrend.map(d => d.present)) %>,
          backgroundColor: 'rgba(34,197,94,.8)',
          borderRadius: 4,
        },
        {
          label: 'Total Attempts',
          data:  <%- JSON.stringify(dailyTrend.map(d => d.total)) %>,
          backgroundColor: 'rgba(59,130,246,.4)',
          borderRadius: 4,
        },
      ],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      scales: {
        x: { grid: { display: false } },
        y: { beginAtZero: true, ticks: { stepSize: 1 } },
      },
      plugins: { legend: { position: 'top' } },
    },
  });
  <% } %>
}());
</script>
<% } %>

<%- include('../partials/layout_end') %>
